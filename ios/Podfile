platform :ios, '16.0'

ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(
    File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__
  )
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(
  File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root
)

flutter_ios_podfile_setup

pre_install do |installer|
  # fix Flutter podspec vendored_frameworks path
  flutter_podspec = File.expand_path(
    '../Flutter/Flutter.podspec', __FILE__
  )
  if File.exist?(flutter_podspec)
    content = File.read(flutter_podspec)
    if content.include?('path/to/nothing')
      content = content.gsub(
        'path/to/nothing',
        'Flutter.xcframework'
      )
      File.write(flutter_podspec, content)
      puts "✅ Fixed Flutter.podspec vendored_frameworks path"
    end
  end
end

target 'Runner' do
  use_frameworks!
  use_modular_headers!
  


  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))

  target 'RunnerTests' do
    inherit! :search_paths
  end
end

target 'DeviceActivityMonitorExtension' do
  use_frameworks!
  use_modular_headers!
end

target 'ShieldConfigurationExtension' do
  use_frameworks!
  use_modular_headers!
end

target 'ShieldActionExtension' do
  use_frameworks!
  use_modular_headers!
end



post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    target.build_configurations.each do |config|
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '16.0'
      config.build_settings['CLANG_WARN_QUOTED_INCLUDE_IN_FRAMEWORK_HEADER'] = '$(inherited)'
    end
  end
end
